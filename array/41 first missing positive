class Solution {
    public int firstMissingPositive(int[] nums) {
        int i;
        Arrays.sort(nums);
        int count=1;
        for(i=0;i<nums.length;i++){
            if(nums[i]<=0){
                continue;
            }
            else if(count==nums[i]){
                count++;
            }
            else if(nums[i]>count){
               
                return count;
            }
            
        }
        return count;
        
        
    }
}
