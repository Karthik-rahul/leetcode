class Solution {
    public int reverse(int x) {
        long ans = 0; 
        int n = Math.abs(x);
        
        while (n > 0) {
            int r=n%10;
            ans = (ans * 10) + r;
            n /= 10;
        }
     
        if (ans > Integer.MAX_VALUE) {
            return 0;
        }
        
    
        return (x < 0) ? (int) -ans : (int) ans;
    }
}
