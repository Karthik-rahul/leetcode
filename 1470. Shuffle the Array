class Solution {
    public int[] shuffle(int[] nums, int n) {
        int i,j;
        int count=0;
        int len=nums.length;
        int arr[] =new int[len];
        i=0;
        j=n;
        while(i<n && j<len){
            
            arr[count++]=nums[i];
            arr[count++]=nums[j];
            i++;
            j++;
        }
        return arr;    
    }
}
