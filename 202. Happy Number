class Solution {
    public boolean isHappy(int n) {
        if(n==1){
            return true;

        }
        if(n==4){
            return false;
        }
        int r,sum=0;
        while(n>0){
            r=n%10;
            sum=sum+(r*r);
            n=n/10;

        }
        return isHappy(sum);
       
    }

}
