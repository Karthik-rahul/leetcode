class Solution {
    public int hammingWeight(int n) {
        char ch;
        int count=0;
        String s=Integer.toBinaryString(n);
        StringBuilder str=new StringBuilder(s);
        for(int i=0;i<str.length();i++){
            ch=str.charAt(i);
            if(ch=='1'){
                count++;
            }
        
        }
        return count;

        
    }
}
