class Solution {
    public int numJewelsInStones(String jewels, String stones) {
        int i,j,count=0;
        for(i=0;i<jewels.length();i++){
            char ch=jewels.charAt(i);
            for(j=0;j<stones.length();j++){
                char st=stones.charAt(j);
                if(ch==st){
                    count++;
                }
            }
        }
        return count;
        
    }
}
