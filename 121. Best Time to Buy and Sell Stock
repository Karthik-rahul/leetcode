class Solution {
    public int maxProfit(int[] prices) {
        int i,j,high,current=prices[0],profit=0;
        for(i=1;i<=prices.length-1;i++){
            if(current>prices[i]){
                current=prices[i];
            }
            high=prices[i]-current;
            if(profit<high){
                profit=high;
            }
        }
        return profit;
    }
}
